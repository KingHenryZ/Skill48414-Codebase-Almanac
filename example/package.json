{
  "name": "taskflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A monorepo task management platform with API, CLI, and shared libraries",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev --workspace=@taskflow/api",
    "build": "npm run build --workspaces",
    "lint": "eslint packages/*/src/**/*.ts",
    "test": "vitest run --workspace"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^9.0.0"
  }
}
